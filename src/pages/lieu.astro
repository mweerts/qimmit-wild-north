---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
---

<BaseLayout title="Le lieu">
	<div class="page container container--narrow">
		<h1>Le lieu</h1>
		<p class="page-intro">
			Propriété à {site.location}, près de Ruka et du lac Ala-Kitka.
		</p>
		<p>
			Le parc à chiens est construit sur place. Les détails d’accès pour les
			visiteurs (parking, conditions hiver / été, etc.) seront ajoutés lorsqu’ils
			seront validés.
		</p>
		<p class="todo">
			TODO : indications d’accès pour les visiteurs — à valider avec Romain.
		</p>
	</div>
</BaseLayout>
