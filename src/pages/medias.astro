---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
---

<BaseLayout title="Médias">
	<div class="page container container--narrow">
		<h1>Médias</h1>
		<p class="page-intro">
			Articles, photographies et vidéos liés à Qimmit Wild North. Seuls les médias
			dont l’usage est autorisé seront publiés ici.
		</p>

		<h2>Presse</h2>
		<ul class="press-list">
			{
				site.press.map((article) => (
					<li class="press-list__item">
						<a href={article.url}>{article.title}</a>
						<p class="press-list__meta">
							{article.source} —{' '}
							<time datetime={article.date}>
								{new Date(article.date).toLocaleDateString('fr-FR', {
									year: 'numeric',
									month: 'long',
									day: 'numeric',
								})}
							</time>
						</p>
					</li>
				))
			}
		</ul>

		<h2>Galerie</h2>
		<p class="todo">
			TODO : sélectionner, optimiser et créditer les photos et vidéos (droits
			d’utilisation à confirmer).
		</p>
	</div>
</BaseLayout>
