---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
---

<BaseLayout title={site.name}>
	<section class="hero container">
		<img
			class="hero__logo"
			src="/brand/logo-finland/dark.svg"
			alt={site.name}
			width="280"
			height="84"
		/>
		<p class="hero__tagline">
			Esquimau canadien et chiens de traîneau, près de Kuusamo
		</p>
		<p class="hero__text">
			Qimmit Wild North est le projet de Romain Weerts en Finlande, autour de
			l’Esquimau canadien (Qimmiq), près du lac Ala-Kitka. Ce site présente le
			projet, les chiens et le lieu tels qu’ils sont aujourd’hui.
		</p>
		<div class="hero__actions">
			<a class="button button--primary" href="/projet">Découvrir le projet</a>
			<a class="button button--secondary" href="/chiens">Rencontrer les chiens</a>
		</div>
	</section>
</BaseLayout>
